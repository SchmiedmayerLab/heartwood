{
  "name": "@heartwood/webui",
  "version": "0.2.0-beta.7",
  "private": true,
  "type": "module",
  "description": "Researcher web UI for Heartwood sessions.",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "dev": "vite --host 127.0.0.1",
    "format:check": "prettier --check .",
    "license:check": "node scripts/check-licenses.mjs",
    "lint": "eslint .",
    "preview": "vite preview --host 127.0.0.1",
    "screenshots:docs": "node scripts/smoke-reference-analysis.cjs --screenshot-dir ../../documentation/assets/screenshots",
    "test": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:gateway": "node scripts/smoke-gateway.cjs",
    "test:jupyter-proxy": "node scripts/smoke-jupyter-proxy.cjs",
    "test:reference-analysis": "node scripts/smoke-reference-analysis.cjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@stanfordspezi/spezi-web-design-system": "0.20.0",
    "@tanstack/react-query": "5.101.4",
    "lucide-react": "1.25.0",
    "react": "19.2.8",
    "react-dom": "19.2.8"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "next": "16.2.11",
    "postcss": "8.5.10",
    "sharp": "0.35.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@stanfordspezi/spezi-web-configurations": "0.7.0",
    "@tailwindcss/postcss": "4.3.3",
    "@testing-library/jest-dom": "7.0.0",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.4",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "9.39.5",
    "eslint-import-resolver-typescript": "4.4.5",
    "jsdom": "29.1.1",
    "prettier": "3.9.6",
    "tailwindcss": "4.3.3",
    "typescript": "6.0.3",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
